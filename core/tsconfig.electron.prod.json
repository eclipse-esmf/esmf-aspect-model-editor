{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "dist",
    "sourceMap": false,
    "noImplicitAny": true,
    "declaration": false,
    "removeComments": true,
    "strict": true,
    "noEmitOnError": true
  },
  "include": [
    "main.ts", "electron/**/*.ts"],
  "exclude": ["node_modules", "tmp", "electron/**/*.spec.ts", "electron/__mocks__", "electron/jest.config.ts"]
}
